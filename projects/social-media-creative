  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    .project-hero { padding: calc(var(--nav-height) + 80px) 0 60px; }
    .project-hero .section-title { margin-bottom: 16px; }
    .project-meta { display: flex; gap: 40px; margin-bottom: 60px; flex-wrap: wrap; }
    .project-meta-item h4 { font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600; margin-bottom: 4px; }
    .project-meta-item p { font-size: 0.95rem; color: var(--color-text-light); }
    .project-description { max-width: 720px; margin-bottom: 60px; }
    .project-description p { font-size: 1.05rem; line-height: 1.8; margin-bottom: 16px; color: var(--color-text); }
    .project-images { display: flex; flex-direction: column; gap: 24px; margin-bottom: 80px; }
    .project-images img { width: 100%; background-color: var(--color-border); }
    .project-nav { display: flex; justify-content: space-between; padding: 40px 0; border-top: 1px solid var(--color-border); }
    .project-nav a { font-size: 0.8rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; position: relative; padding: 4px 0; }
    .project-nav a::after { content: ''; position: absolute; bottom: 0; left: 0; width: 0; height: 1.5px; background-color: var(--color-text); transition: width 0.3s ease; }
    .project-nav a:hover::after { width: 100%; }

    /* VIDEO GRID STYLES */
    .video-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
      margin-bottom: 80px;
    }
    .video-wrapper {
      position: relative;
      padding-bottom: 56.25%; /* 16:9 aspect ratio */
      height: 0;
      overflow: hidden;
      background-color: var(--color-border);
    }
    .video-wrapper iframe {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }
    .video-caption {
      margin-top: 12px;
    }
    .video-caption h3 {
      font-family: var(--font-heading);
      font-size: 1.1rem;
      font-weight: 500;
      margin-bottom: 4px;
    }
    .video-caption p {
      font-size: 0.8rem;
      color: var(--color-text-light);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    @media (max-width: 600px) {
      .video-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
